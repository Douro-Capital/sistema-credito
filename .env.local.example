# Renomeie este arquivo para .env.local e preencha os valores.
# O arquivo .env.local NUNCA deve ser commitado no git.

# URL pública do dashboard.json no Vercel Blob.
# Obtida ao rodar upload_dashboard.py — ex.:
# https://abc123xyz.public.blob.vercel-storage.com/dashboard.json
BLOB_URL=

# Token de leitura/escrita do Vercel Blob (necessário só para upload_dashboard.py).
# Gerado em: Vercel → seu projeto → Storage → Blob → tokens
BLOB_READ_WRITE_TOKEN=
